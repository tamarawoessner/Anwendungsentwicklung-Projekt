@patch("app.application.station_data_service.read_station_data_seasons")
@patch("app.application.station_data_service.read_station_data_year")
@patch("app.application.station_data_service.read_years_for_station")
@patch("app.application.station_data_service.read_location_for_station")
def test_seasons_only_valid_keys_and_elements_are_called(
    mock_loc, mock_years, mock_read_year, mock_read_seasons
):
    mock_loc.return_value = {"station_id": "X"}
    mock_years.return_value = None
    mock_read_year.return_value = []

    def seasons_side_effect(conn, station_id, start_year, end_year, season, element):
        return [{"season": season, "element": element}]

    mock_read_seasons.side_effect = seasons_side_effect

    res = get_station_data(
        conn=None,
        station_id="X",
        start_year=2000,
        end_year=2001,
        selection={
            "year": "TMAX",
            "winter": {"tmin": True},    # valid -> WINTER/TMIN
            "spring": {"tmax": True},    # valid -> SPRING/TMAX
            "summer": None,              # invalid element -> skipped
            "autumn": "BOTH",            # valid -> AUTUMN/BOTH
            "unknown": "BOTH",           # invalid season -> skipped
        },
    )

    # Year
    assert res["year"]["element"] == "TMAX"
    mock_read_year.assert_called_once_with(
        conn=None, station_id="X", start_year=2000, end_year=2001, element="TMAX"
    )

    # Seasons
    assert set(res["seasons"].keys()) == {"WINTER", "SPRING", "AUTUMN"}
    assert res["seasons"]["WINTER"]["element"] == "TMIN"
    assert res["seasons"]["SPRING"]["element"] == "TMAX"
    assert res["seasons"]["AUTUMN"]["element"] == "BOTH"

    # Ensure repo was called exactly 3 times (summer/unknown skipped)
    assert mock_read_seasons.call_count == 3


